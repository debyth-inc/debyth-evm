    function testCannotCancelAlreadyCanceledMandate() public{
        vm.prank(executor);
        bytes32 mandateId = generateMandateId();
        mandate.createMandate(
            payer,
            mandateId,
            Mandate.CreateMandateParams({
                payee: payee,
